{
  "name": "@nfq/eslint-config",
  "description": "Eslint configuration for all nfq projects",
  "author": ".NFQ | Christoph Kruppe",
  "version": "3.3.1",
  "keywords": [
    "eslint",
    "eslintconfig",
    "codestyle",
    "config"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nfqde/eslint-config-nfq.git"
  },
  "bugs": {
    "url": "https://github.com/nfqde/eslint-config-nfq/issues"
  },
  "homepage": "https://github.com/nfqde/eslint-config-nfq#readme",
  "template": {
    "version": "1.3.4",
    "name": "nfq-npm-modules-template",
    "path": "https://github.com/nfqde/nfq-npm-modules-template.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js",
      "types": "./types/index.d.ts"
    },
    "./rules/common/eslint": {
      "import": "./dist/esm/rules/common/eslint/index.js",
      "require": "./dist/rules/common/eslint/index.js",
      "types": "./types/rules/common/eslint/index.d.ts"
    },
    "./rules/common/plugins": {
      "import": "./dist/esm/rules/common/plugins/index.js",
      "require": "./dist/rules/common/plugins/index.js",
      "types": "./types/rules/common/plugins/index.d.ts"
    },
    "./rules/cypress/overrides": {
      "import": "./dist/esm/rules/cypress/overrides/resets.js",
      "require": "./dist/rules/cypress/overrides/index.js",
      "types": "./types/rules/cypress/overrides/index.d.ts"
    },
    "./rules/cypress/plugins": {
      "import": "./dist/esm/rules/cypress/plugins/index.js",
      "require": "./dist/rules/cypress/plugins/index.js",
      "types": "./types/rules/cypress/plugins/index.d.ts"
    },
    "./rules/node/plugins": {
      "import": "./dist/esm/rules/node/plugins/node.js",
      "require": "./dist/rules/node/plugins/index.js",
      "types": "./types/rules/node/plugins/index.d.ts"
    },
    "./rules/react/plugins": {
      "import": "./dist/esm/rules/react/plugins/index.js",
      "require": "./dist/rules/react/plugins/index.js",
      "types": "./types/rules/react/plugins/index.d.ts"
    },
    "./rules/storybook/overrides": {
      "import": "./dist/esm/rules/storybook/overrides/index.js",
      "require": "./dist/rules/storybook/overrides/index.js",
      "types": "./types/rules/typescript/overrides/index.d.ts"
    },
    "./rules/typescript/overrides": {
      "import": "./dist/esm/rules/typescript/overrides/index.js",
      "require": "./dist/rules/typescript/overrides/index.js",
      "types": "./types/rules/typescript/overrides/index.d.ts"
    },
    "./rules/typescript/plugins": {
      "import": "./dist/esm/rules/typescript/plugins/index.js",
      "require": "./dist/rules/typescript/plugins/index.js",
      "types": "./types/rules/typescript/plugins/index.d.ts"
    }
  },
  "types": "types/index.d.ts",
  "sideEffects": [
    "cypress/**"
  ],
  "scripts": {
    "build": "pnpm cross-env NODE_ENV=production rollup -c && pnpm tsc -p tsconfig-build.json",
    "watch": "pnpm cross-env NODE_ENV=dev rollup -c -w",
    "deploy": "standard-version && git push --follow-tags origin main && pnpm publish",
    "check:types": "tsc -p .",
    "lint": "pnpm cross-env TIMING=1 pnpm eslint ./src --ext='.js' --ext='.jsx' --ext='.ts' --ext='.tsx'",
    "lint:report": "pnpm eslint --output-file eslint_report.json --format json --ext='.js, .jsx, .ts, .tsx' ./src",
    "merge:files": "pnpm mochawesome-merge \"./cypress/reports/mochawesome*.json\" > \"./cypress/reports/index.json\"",
    "prepublishOnly": "pnpm run build",
    "test": "pnpm cross-env CYPRESS_INTERNAL_BROWSER_CONNECT_TIMEOUT=300000 pnpm cypress run --component && pnpm merge:files",
    "test:open": "pnpm cross-env NODE_ENV=test pnpm cypress open --component"
  },
  "peerDependencies": {
    "eslint": ">= 9"
  },
  "dependencies": {
    "@emotion/eslint-plugin": "^11.12.0",
    "@nfq/eslint-plugin": "^0.8.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@typescript-eslint/utils": "^8.65.0",
    "confusing-browser-globals": "^1.0.11",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-array-func": "^5.1.1",
    "eslint-plugin-cypress": "^6.4.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^63.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^18.2.2",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-redos": "4.5.0",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sort-destructure-keys": "^3.0.0",
    "eslint-plugin-styled-components-order": "^1.0.3",
    "globals": "^17.7.0",
    "natural-compare": "^1.4.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^8.0.2",
    "@babel/plugin-syntax-import-assertions": "^7.29.7",
    "@babel/plugin-transform-class-static-block": "^8.0.1",
    "@babel/plugin-transform-typescript": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@cypress/code-coverage": "^4.0.3",
    "@lopatnov/rollup-plugin-uglify": "^5.0.0",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/cypress__code-coverage": "^3.10.2",
    "@types/estree": "^1.0.9",
    "@types/natural-compare": "^1.4.3",
    "@types/node": "^26.1.1",
    "@types/webpack": "^5.28.5",
    "@typescript-eslint/rule-tester": "^8.65.0",
    "@typescript-eslint/types": "^8.65.0",
    "babel-loader": "^10.1.1",
    "babel-plugin-istanbul": "^8.0.2",
    "babel-plugin-styled-components": "^2.3.0",
    "clean-webpack-plugin": "^4.0.0",
    "cross-env": "^10.1.0",
    "cypress": "^15.19.0",
    "eslint": "^9.39.2",
    "html-webpack-plugin": "^5.6.7",
    "mocha": "^11.7.6",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "node-polyfill-webpack-plugin": "^4.1.0",
    "rollup": "^4.62.2",
    "rollup-plugin-cleaner": "^1.0.0",
    "terser": "^5.49.0",
    "typescript": "^5.9.3",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "5.2.6"
  },
  "standard-version": {
    "scripts": {
      "prebump": "nfqBump"
    }
  },
  "browserslist": [
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}